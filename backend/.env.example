NODE_ENV=development
PORT=4000

# Required
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/grosery?schema=public

# Required: use a long random secret (at least 32 chars)
JWT_ACCESS_SECRET=change_me_to_a_long_random_secret
JWT_ACCESS_EXPIRES_IN=8h
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

BCRYPT_SALT_ROUNDS=12
PASSWORD_RESET_EXPIRES_MINUTES=15
